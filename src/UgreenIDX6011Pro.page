<?php
/* UGREEN iDX6011 Pro front-panel settings.
 * Writes /update.php -> the plugin's panel/settings.cfg on flash, then runs
 * restart.sh (installed under the webGUI docroot so update.php accepts it as
 * a #command) to re-apply the dashboard + LED colours live.
 * The picker CSS/JS live in external assets (idxcp.css / idxcp.js): an inline
 * <script> placed after a markdown="1" form is mangled by Unraid's MarkdownExtra
 * pass, whereas external <link>/<script src> one-liners are markdown-safe.
 * Colours are stored as BARE 6-hex (no leading #) to match the daemon's writer
 * and to round-trip cleanly through parse_ini_file. */
$plugin  = 'ugreen-idx6011-pro';
$cfgfile = "/boot/config/plugins/$plugin/panel/settings.cfg";
$cfg     = file_exists($cfgfile) ? (@parse_ini_file($cfgfile) ?: []) : [];
$val = function($k, $def = '') use ($cfg) { return isset($cfg[$k]) ? $cfg[$k] : $def; };
$asset = function($f) use ($plugin) {                 /* cache-busted webGUI asset URL */
    return "/plugins/$plugin/$f?v=" . (@filemtime("/usr/local/emhttp/plugins/$plugin/$f") ?: '1');
};

/* detect real network interfaces for the "primary" picker */
$ifaces = [];
foreach (glob('/sys/class/net/*') as $p) {
    $n = basename($p);
    if ($n === 'lo' || $n === 'bonding_masters') continue;
    if (preg_match('/^(veth|docker|tunl|sit|vnet|br-|dummy|wg)/', $n)) continue;
    $ifaces[] = $n;
}
sort($ifaces);

function opts($items, $cur) {
    foreach ($items as $v => $lbl)
        echo '<option value="' . htmlspecialchars($v) . '"' .
             ((string)$cur === (string)$v ? ' selected' : '') . '>' .
             htmlspecialchars($lbl) . '</option>';
}
/* emit a colour control: swatch chip (opens native picker) + # + hex field, a
 * preset-dot ribbon, and a rotating reset. $cls tags the section (idx-theme /
 * idx-led) for the per-section reset buttons. Stores/loads BARE 6-hex. */
function colorField($cfg, $name, $default, $cls) {
    $def = strtolower(ltrim($default, '#'));
    $v   = isset($cfg[$name]) ? strtolower(ltrim(trim($cfg[$name]), '#')) : '';
    if (!preg_match('/^[0-9a-f]{6}$/', $v)) $v = $def;
    $n = htmlspecialchars($name);
    echo '<span class="idxcp" data-label="'.$n.'">'
       . '<span class="idxcp-field">'
       .   '<button type="button" class="idxcp-chip" aria-label="'.$n.' '._('colour').'"></button>'
       .   '<span class="idxcp-hash" aria-hidden="true">#</span>'
       .   '<input class="idxcp-hex '.$cls.'" type="text" name="'.$n.'" value="'.$v.'" data-default="'.$def.'"'
       .        ' maxlength="7" spellcheck="false" autocomplete="off" autocapitalize="off" aria-label="'.$n.' hex">'
       .   '<input class="idxcp-native" type="color" tabindex="-1" aria-hidden="true" value="#'.$v.'">'
       . '</span>'
       . '<span class="idxcp-presets" role="group" aria-label="'.$n.' '._('presets').'"></span>'
       . '<button type="button" class="idxcp-reset" title="'._('Restore default').'" aria-label="'._('Restore default').'"></button>'
       . '</span>';
}
?>
<link rel="stylesheet" href="<?=$asset('idxcp.css')?>">
<script src="<?=$asset('idxcp.js')?>"></script>

<form markdown="1" name="idx_settings" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="<?=$plugin?>/panel/settings.cfg">
<input type="hidden" name="#command" value="plugins/<?=$plugin?>/restart.sh">

_(LCD brightness, %)_:
: <input type="number" name="BRIGHTNESS" min="5" max="100" step="1" value="<?=htmlspecialchars($val('BRIGHTNESS','75'))?>">

_(Stats refresh, seconds)_:
: <input type="number" name="INTERVAL" min="1" max="10" step="1" value="<?=htmlspecialchars($val('INTERVAL','1'))?>">

_(Auto-rotate pages every)_:
: <select name="ROTATE"><?php opts([0=>'Off',10=>'10 seconds',20=>'20 seconds',30=>'30 seconds',60=>'60 seconds'], $val('ROTATE','0')); ?></select>

_(Screen off after idle)_:
: <select name="SCREEN_OFF_MIN"><?php opts([0=>'Never',1=>'1 minute',5=>'5 minutes',15=>'15 minutes'], $val('SCREEN_OFF_MIN','0')); ?></select>

_(Night mode &mdash; clamp brightness to 15%)_:
: <select name="NIGHT"><?php opts([0=>'Off',1=>'On'], $val('NIGHT','0')); ?></select>

_(Front-panel LEDs)_:
: <select name="LEDS"><?php opts([1=>'On',0=>'Off'], $val('LEDS','1')); ?></select>

_(Network rate units)_:
: <select name="NET_UNITS"><?php opts(['bits'=>'Bits — Kbps / Mbps (matches Unraid)','bytes'=>'Bytes — KB/s / MB/s'], $val('NET_UNITS','bits')); ?></select>

_(Primary network interface &mdash; shown on Overview &amp; Home)_:
: <select name="PRIMARY_IFACE">
  <option value=""<?=$val('PRIMARY_IFACE','')===''?' selected':''?>>Auto (default route)</option>
  <?php foreach ($ifaces as $n) echo '<option value="' . htmlspecialchars($n) . '"' . ($val('PRIMARY_IFACE','') === $n ? ' selected' : '') . '>' . htmlspecialchars($n) . '</option>'; ?>
  </select>

&nbsp;
: **_(Theme colours &mdash; leave default for the Unraid look)_**

_(Accent &mdash; spines, gauges, dots)_:
: <?php colorField($cfg,'COL_ACCENT','f15a2c','idx-theme'); ?>

_(Gradient start)_:
: <?php colorField($cfg,'COL_GRAD_A','e22828','idx-theme'); ?>

_(Gradient end)_:
: <?php colorField($cfg,'COL_GRAD_B','ff8c2f','idx-theme'); ?>

_(Background)_:
: <?php colorField($cfg,'COL_BG','1b1b1b','idx-theme'); ?>

_(Card fill)_:
: <?php colorField($cfg,'COL_CARD','262626','idx-theme'); ?>

_(Text)_:
: <?php colorField($cfg,'COL_TEXT','f2f2f2','idx-theme'); ?>

_(Healthy / OK)_:
: <?php colorField($cfg,'COL_OK','3fb950','idx-theme'); ?>

_(Warning)_:
: <?php colorField($cfg,'COL_WARN','f0a020','idx-theme'); ?>

_(Critical)_:
: <?php colorField($cfg,'COL_BAD','e22828','idx-theme'); ?>

&nbsp;
: <input type="button" class="idx-defbtn" value="_(Restore theme defaults)_" onclick="idxReset('idx-theme')">

&nbsp;
: **_(Front-panel LEDs)_**

_(Power light)_:
: <select name="LED_POWER" class="idx-led" data-default="1"><?php opts([1=>'On',0=>'Off'], $val('LED_POWER','1')); ?></select>

_(Activity mode &mdash; light disk/LAN LEDs only while busy)_:
: <select name="LED_ACTIVITY" class="idx-led" data-default="0"><?php opts([0=>'Off — always solid',1=>'On — pulse on I/O'], $val('LED_ACTIVITY','0')); ?></select>

_(Network / LAN light)_:
: <?php colorField($cfg,'LED_LAN','0064ff','idx-led'); ?>

_(Disk light &mdash; healthy)_:
: <?php colorField($cfg,'LED_DISK_OK','00ff00','idx-led'); ?>

_(Disk light &mdash; warning)_:
: <?php colorField($cfg,'LED_DISK_WARN','ff7800','idx-led'); ?>

_(Disk light &mdash; critical)_:
: <?php colorField($cfg,'LED_DISK_BAD','ff0000','idx-led'); ?>

_(Disk light &mdash; spun down / asleep)_:
: <?php colorField($cfg,'LED_DISK_STANDBY','ffffff','idx-led'); ?>

&nbsp;
: <input type="button" class="idx-defbtn" value="_(Restore LED defaults)_" onclick="idxReset('idx-led')">

&nbsp;
: <span class="buttons-spaced"><input type="submit" name="#apply" value="_(Apply)_" disabled><input type="button" value="_(Done)_" onclick="done()"></span>
</form>

> Changes are written to the plugin's `settings.cfg` and the dashboard restarts to
> apply them. The same settings are editable live from the panel's own **SETTINGS**
> page.
