.idx-cp-native{position:absolute;width:1px;height:1px;padding:0;margin:-1px;border:0;opacity:0;overflow:hidden;pointer-events:none}
.idx-cp-swatch{width:26px;height:26px;border-radius:7px;cursor:pointer;flex:0 0 auto;
  border:1px solid rgba(255,255,255,.28);
  box-shadow:inset 0 0 0 2px rgba(0,0,0,.35),0 1px 3px rgba(0,0,0,.45);
  transition:transform .08s ease,box-shadow .12s ease}
.idx-cp-swatch:hover{transform:scale(1.08);box-shadow:inset 0 0 0 2px rgba(0,0,0,.35),0 2px 6px rgba(0,0,0,.55)}
.idx-cp-swatch:focus-visible{outline:2px solid #ff8c2f;outline-offset:2px}
.idx-cp-hash{color:#8a8a8a;font-family:ui-monospace,Menlo,Consolas,monospace;margin-right:-4px;user-select:none}
.idx-cp-hex{width:84px;font-family:ui-monospace,Menlo,Consolas,monospace;text-transform:lowercase;letter-spacing:.5px}
.idx-cp-reset{background:none;border:0;color:#8a8a8a;cursor:pointer;font-size:16px;line-height:1;padding:2px 5px;border-radius:6px;transition:color .12s,background .12s}
.idx-cp-reset:hover{color:#ff8c2f;background:rgba(255,255,255,.07)}
.idx-defbtn{font-size:.85em;margin-top:2px}
</style>
