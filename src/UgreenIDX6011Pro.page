: <span class="buttons-spaced"><input type="submit" name="#apply" value="_(Apply)_" disabled><input type="button" value="_(Done)_" onclick="done()"></span>
</form>
<script>
(function(){
  function norm(h){ h=(h||'').replace(/[^0-9a-fA-F]/g,'').toLowerCase();
    if(h.length===3) h=h.split('').map(function(c){return c+c;}).join('');
    return /^[0-9a-f]{6}$/.test(h)?h:null; }
  /* Unraid's change-listener ignores type=color; enable Apply explicitly. */
  function markChanged(el){ var f=el.closest('form'); if(!f) return;
    f.querySelectorAll('input[value="Apply"]').forEach(function(b){b.disabled=false;});
    try{ formHasUnsavedChanges=true; }catch(e){} }
  function setVal(cp, hex, fire){
    var h=norm(hex); if(!h) return;
    var hexIn=cp.querySelector('.idx-cp-hex'), sw=cp.querySelector('.idx-cp-swatch'), nat=cp.querySelector('.idx-cp-native');
    hexIn.value=h; sw.style.background='#'+h; if(nat) nat.value='#'+h;
    if(fire){ hexIn.dispatchEvent(new Event('change',{bubbles:true})); markChanged(hexIn); }
  }
  document.querySelectorAll('.idx-cp').forEach(function(cp){
    var hexIn=cp.querySelector('.idx-cp-hex'), sw=cp.querySelector('.idx-cp-swatch'),
        nat=cp.querySelector('.idx-cp-native'), rst=cp.querySelector('.idx-cp-reset');
    setVal(cp, hexIn.value, false);
    sw.addEventListener('click', function(){ if(nat) nat.click(); });
    sw.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); if(nat) nat.click(); }});
    if(nat) nat.addEventListener('input', function(){ setVal(cp, nat.value, true); });
    hexIn.addEventListener('input', function(){ var h=norm(hexIn.value);
      if(h){ sw.style.background='#'+h; if(nat) nat.value='#'+h; markChanged(hexIn); } });
    hexIn.addEventListener('blur', function(){ setVal(cp, hexIn.value, true); });
    if(rst) rst.addEventListener('click', function(){ setVal(cp, hexIn.getAttribute('data-default'), true); });
  });
  window.idxReset=function(cls){
    document.querySelectorAll('.idx-cp-hex.'+cls).forEach(function(hexIn){
      setVal(hexIn.closest('.idx-cp'), hexIn.getAttribute('data-default'), true); });
    document.querySelectorAll('select.'+cls+'[data-default]').forEach(function(el){
      el.value=el.getAttribute('data-default');
      el.dispatchEvent(new Event('change',{bubbles:true})); markChanged(el); });
  };
})();
</script>

> Changes are written to the plugin's `settings.cfg` and the dashboard restarts to
> apply them. The same settings are editable live from the panel's own **SETTINGS**
> page.
