<?php
/* UGREEN iDX6011 Pro settings. This container page hosts the tab bar AND is itself
 * the first tab (Screen / display behaviour + wallpaper/logo). The other tabs are
 * separate child .page files grouped under it via Menu="UgreenIDX6011Pro:N":
 *   - UgreenIDX6011ProLighting.page  (Menu="UgreenIDX6011Pro:1", Title="Lighting")
 *   - UgreenIDX6011ProLayout.page    (Menu="UgreenIDX6011Pro:2", Title="Display")
 * Colours, font and text sizes live on the Display tab's Theme sub-tab. Writes the
 * plugin's panel/settings.cfg (update.php preserves the other tabs' keys) and runs
 * restart.sh to re-apply the dashboard live. */
require_once '/usr/local/emhttp/plugins/ugreen-idx6011-pro/idxcp-inc.php';
$cfg    = idx_cfg();
$ifaces = idx_ifaces();
?>
<script src="<?=idx_asset('idxcp.js')?>"></script>

<form markdown="1" name="idx_screen" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="ugreen-idx6011-pro/panel/settings.cfg">
<input type="hidden" name="#command" value="plugins/ugreen-idx6011-pro/restart.sh">

<div class="idxth-grid">
  <label>_(LCD brightness, %)_</label>
  <input type="number" name="BRIGHTNESS" min="5" max="100" step="1" value="<?=htmlspecialchars(idx_val($cfg,'BRIGHTNESS','75'))?>">

  <label>_(Stats refresh, seconds)_</label>
  <input type="number" name="INTERVAL" min="1" max="10" step="1" value="<?=htmlspecialchars(idx_val($cfg,'INTERVAL','1'))?>">

  <label>_(Auto-rotate pages every)_</label>
  <select name="ROTATE"><?php idx_opts([0=>'Off',10=>'10 seconds',20=>'20 seconds',30=>'30 seconds',60=>'60 seconds'], idx_val($cfg,'ROTATE','0')); ?></select>

  <label>_(Screen off after idle)_</label>
  <select name="SCREEN_OFF_MIN"><?php idx_opts([0=>'Never',1=>'1 minute',5=>'5 minutes',15=>'15 minutes'], idx_val($cfg,'SCREEN_OFF_MIN','0')); ?></select>

  <label>_(Power-save schedule)_</label>
  <select name="POWERSAVE"><?php idx_opts([0=>'Off',1=>'On'], idx_val($cfg,'POWERSAVE','0')); ?></select>
  <div class="idxth-note">_(Turns the screen and disk/LAN LEDs off between the times below, using the Unraid timezone. A tap wakes the screen for 30s; the power LED stays on.)_</div>

  <label>_(Power-save from)_</label>
  <input type="time" name="POWERSAVE_START" value="<?=htmlspecialchars(idx_val($cfg,'POWERSAVE_START','23:00'))?>">

  <label>_(Power-save until)_</label>
  <input type="time" name="POWERSAVE_END" value="<?=htmlspecialchars(idx_val($cfg,'POWERSAVE_END','07:00'))?>">

  <label>_(Night mode &mdash; clamp brightness to 15%)_</label>
  <select name="NIGHT"><?php idx_opts([0=>'Off',1=>'On'], idx_val($cfg,'NIGHT','0')); ?></select>

  <label>_(Fan mode)_</label>
  <select name="FAN_MODE"><?php idx_opts(['auto'=>'Auto (firmware controls the fans)','silent'=>'Silent','quiet'=>'Quiet','turbo'=>'Turbo','max'=>'Max (all fans 100%)'], idx_val($cfg,'FAN_MODE','auto')); ?></select>
  <div class="idxth-note">_(Silent/Quiet/Turbo drive <strong>all four fans</strong> on temperature curves &mdash; CPU fans by CPU temp, case fans by the hottest disk &mdash; never below 25% so they never stall, with a forced 100% at critical temps. <strong>Max</strong> runs every fan at 100% regardless of temperature. If the panel process stops, the fans hold their last speed until it restarts.)_</div>

  <label>_(Network rate units)_</label>
  <select name="NET_UNITS"><?php idx_opts(['bits'=>'Bits — Kbps / Mbps (matches Unraid)','bytes'=>'Bytes — KB/s / MB/s'], idx_val($cfg,'NET_UNITS','bits')); ?></select>

  <label>_(Primary network interface &mdash; shown on Overview &amp; Home)_</label>
  <select name="PRIMARY_IFACE">
    <option value=""<?=idx_val($cfg,'PRIMARY_IFACE','')===''?' selected':''?>>Auto (default route)</option>
    <?php foreach ($ifaces as $n) echo '<option value="' . htmlspecialchars($n) . '"' . (idx_val($cfg,'PRIMARY_IFACE','') === $n ? ' selected' : '') . '>' . htmlspecialchars($n) . '</option>'; ?>
  </select>
</div>

