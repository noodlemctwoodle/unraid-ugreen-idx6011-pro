<?php
/* UGREEN iDX6011 Pro - Layout tab: a Theme sub-tab (colours + font + text sizes)
 * followed by per-page module editors, each with a LIVE preview rendered by the
 * real dashboard (preview.php -> panel_dash --preview). The catalog + current
 * layouts arrive via data-attributes on #idxlayout (an inline <script> would be
 * mangled by the markdown pass); the theme controls live in #idxtheme, which
 * idxlayout.js moves into the Theme tab. All fields POST to settings.cfg. */
require_once '/usr/local/emhttp/plugins/ugreen-idx6011-pro/idxcp-inc.php';
$cfg     = idx_cfg();
$catalog = trim(@shell_exec('/usr/local/bin/panel_dash --modules 2>/dev/null'));
$layouts = trim(@shell_exec('/usr/local/bin/panel_dash --layouts 2>/dev/null'));
if ($catalog === '') $catalog = '[]';
if ($layouts === '') $layouts = '{}';
?>
<script src="<?=idx_asset('idxcp.js')?>"></script>
<script src="<?=idx_asset('idxlayout.js')?>"></script>

<form markdown="1" name="idx_layout" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="ugreen-idx6011-pro/panel/settings.cfg">
<input type="hidden" name="#command" value="plugins/ugreen-idx6011-pro/restart.sh">

<div id="idxlayout" data-catalog="<?=htmlspecialchars($catalog)?>" data-layouts="<?=htmlspecialchars($layouts)?>"></div>

<div id="idxtheme" style="display:none">
  <div class="idxth-grid">
    <label>_(Dashboard font)_</label>
    <select name="FONT" class="idx-theme" data-default="RobotoCondensed"><?php idx_opts(['RobotoCondensed'=>'Roboto Condensed','Inter'=>'Inter','JetBrainsMono'=>'JetBrains Mono','BarlowSemiCond'=>'Barlow Semi Condensed','Montserrat'=>'Montserrat'], idx_val($cfg,'FONT','RobotoCondensed')); ?></select>

    <label>_(Heading size)_</label>
    <select name="HEAD_SCALE" class="idx-theme" data-default="100"><?php idx_opts([90=>'90%',100=>'100% (default)',115=>'115%',130=>'130%',150=>'150%'], idx_val($cfg,'HEAD_SCALE','100')); ?></select>

    <label>_(Text size)_</label>
    <select name="TEXT_SCALE" class="idx-theme" data-default="100"><?php idx_opts([90=>'90%',100=>'100% (default)',110=>'110%',120=>'120%',130=>'130%'], idx_val($cfg,'TEXT_SCALE','100')); ?></select>

    <label>_(Accent)_</label><?php idx_colorField($cfg,'COL_ACCENT','f15a2c','idx-theme'); ?>
    <label>_(Gradient start)_</label><?php idx_colorField($cfg,'COL_GRAD_A','e22828','idx-theme'); ?>
    <label>_(Gradient end)_</label><?php idx_colorField($cfg,'COL_GRAD_B','ff8c2f','idx-theme'); ?>
    <label>_(Background)_</label><?php idx_colorField($cfg,'COL_BG','1b1b1b','idx-theme'); ?>
    <label>_(Card fill)_</label><?php idx_colorField($cfg,'COL_CARD','262626','idx-theme'); ?>
    <label>_(Text)_</label><?php idx_colorField($cfg,'COL_TEXT','f2f2f2','idx-theme'); ?>
    <label>_(Healthy / OK)_</label><?php idx_colorField($cfg,'COL_OK','3fb950','idx-theme'); ?>
    <label>_(Warning)_</label><?php idx_colorField($cfg,'COL_WARN','f0a020','idx-theme'); ?>
    <label>_(Critical)_</label><?php idx_colorField($cfg,'COL_BAD','e22828','idx-theme'); ?>
  </div>
  <p><input type="button" value="_(Restore theme defaults)_" onclick="idxReset('idx-theme')"></p>
</div>

&nbsp;
: <span class="buttons-spaced"><input type="submit" name="#apply" value="_(Apply)_" disabled><input type="button" value="_(Done)_" onclick="done()"></span>
</form>

> Start on the **Theme** tab for colours, font and text sizes, then pick a page tab to
> reorder / add / remove / restyle its modules or toggle it off. The **live preview** is
> rendered by the actual dashboard. **Apply** writes everything to `settings.cfg` and
> restarts the panel; the same settings drive the physical screen.
