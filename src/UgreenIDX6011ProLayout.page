  <p><input type="button" value="_(Restore theme defaults)_" onclick="idxReset('idx-theme')"></p>
  <div class="idxth-uploads">
    <div class="idxth-sec">_(Wallpaper &amp; header logo)_</div>
    <div class="idxpick" data-key="WALLPAPER">
