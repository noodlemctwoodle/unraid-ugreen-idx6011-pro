<?php
/* UGREEN iDX6011 Pro - Lighting tab: front-panel LED behaviour + colours. Uses the
 * same label|control grid (.idxth-grid) as the Display > Theme tab so both share
 * one design. Writes the plugin's panel/settings.cfg (update.php preserves the
 * other tabs' keys) and runs restart.sh, which restarts the LED monitor. Controls
 * are native Unraid form elements; idxcp.js syncs swatch<->hex, injects the shared
 * grid CSS, and enables Apply. */
require_once '/usr/local/emhttp/plugins/ugreen-idx6011-pro/idxcp-inc.php';
$cfg = idx_cfg();
?>
<script src="<?=idx_asset('idxcp.js')?>"></script>

<form markdown="1" name="idx_lighting" method="POST" action="/update.php" target="progressFrame">
<input type="hidden" name="#file" value="ugreen-idx6011-pro/panel/settings.cfg">
<input type="hidden" name="#command" value="plugins/ugreen-idx6011-pro/restart.sh">

<div class="idxth-grid">
  <label>_(Front-panel LEDs)_</label>
  <select name="LEDS" class="idx-led" data-default="1"><?php idx_opts([1=>'On',0=>'Off'], idx_val($cfg,'LEDS','1')); ?></select>

  <label>_(Power light)_</label>
  <select name="LED_POWER" class="idx-led" data-default="1"><?php idx_opts([1=>'On',0=>'Off'], idx_val($cfg,'LED_POWER','1')); ?></select>

  <label>_(Activity mode &mdash; blink on I/O, solid when idle)_</label>
  <select name="LED_ACTIVITY" class="idx-led" data-default="0"><?php idx_opts([0=>'Off — always solid',1=>'On — blink on I/O'], idx_val($cfg,'LED_ACTIVITY','0')); ?></select>

  <div class="idxth-sec">_(LED colours)_</div>
  <label>_(Network / LAN light)_</label><?php idx_colorField($cfg,'LED_LAN','0064ff','idx-led'); ?>
  <label>_(Disk light &mdash; healthy)_</label><?php idx_colorField($cfg,'LED_DISK_OK','00ff00','idx-led'); ?>
  <label>_(Disk light &mdash; warning)_</label><?php idx_colorField($cfg,'LED_DISK_WARN','ff7800','idx-led'); ?>
  <label>_(Disk light &mdash; critical)_</label><?php idx_colorField($cfg,'LED_DISK_BAD','ff0000','idx-led'); ?>
  <label>_(Disk light &mdash; spun down / asleep)_</label><?php idx_colorField($cfg,'LED_DISK_STANDBY','ffffff','idx-led'); ?>
</div>
<p><input type="button" value="_(Restore LED defaults)_" onclick="idxReset('idx-led')"></p>

&nbsp;
: <span class="buttons-spaced"><input type="submit" name="#apply" value="_(Apply)_" disabled><input type="button" value="_(Done)_" onclick="done()"></span>
</form>

> Changes are written to the plugin's `settings.cfg` and the LED monitor restarts to
> apply them. The same settings are editable live from the panel's own **SETTINGS** page.
